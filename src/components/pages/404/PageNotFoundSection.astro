---
import type { Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";
import { getPath } from "@i18n/utils.ts";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  class="relative flex flex-col items-center justify-center pb-12 text-center overflow-hidden"
>
  <span
    class="absolute text-[10rem] md:text-[14rem] font-serif italic font-bold text-blue-900/5 select-none leading-none pointer-events-none"
  >
    404
  </span>

  <div class="relative flex flex-col items-center gap-4">
    <span
      class="text-6xl md:text-8xl font-serif italic font-bold text-blue-900"
    >
      404
    </span>

    <h1 class="section-heading">{t("PageNotFoundSection.title")}</h1>
    <p class="text-gray-600 max-w-sm">
      {t("PageNotFoundSection.subtitle")}
    </p>

    <div class="flex gap-4 mt-2">
      <a href={getPath(lang, "")} class="button-primary"
        >{t("PageNotFoundSection.gotoIndex")}</a
      >
      <a href={getPath(lang, "contacto")} class="button-secondary"
        >{t("PageNotFoundSection.gotoContact")}</a
      >
    </div>
  </div>
</section>
