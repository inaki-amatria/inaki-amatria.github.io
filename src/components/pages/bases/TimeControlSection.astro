---
import type { Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="ritmo-de-juego" class="content-section">
  <h2 class="section-heading">{t("TimeControlSection.title")}</h2>

  <p>
    {t("TimeControlSection.p1")}
  </p>

  <p>
    {t("TimeControlSection.p2")}
  </p>
</section>
