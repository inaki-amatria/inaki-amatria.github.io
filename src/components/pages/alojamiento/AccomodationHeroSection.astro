---
import { Image } from "astro:assets";

import RiasBaixas from "@assets/images/RiasBaixas.webp";

export interface Props {
  class?: string;
}

const { class: extraClass = "" } = Astro.props;
---

<div
  class:list={["relative overflow-hidden rounded-3xl shadow-lg", extraClass]}
>
  <Image
    src={RiasBaixas}
    alt="Costa de las Rías Baixas"
    class="absolute inset-0 w-full h-full object-cover"
    quality="high"
    loading="eager"
  />

  <div
    class="absolute inset-0 bg-gradient-to-t from-blue-900/80 via-blue-900/40 to-transparent"
  >
  </div>

  <div class="relative h-full flex flex-col justify-end p-6 gap-4">
    <span class="text-xs font-bold uppercase tracking-widest text-blue-50">
      Tu estancia durante el torneo
    </span>

    <h1 class="text-white text-3xl font-bold font-serif italic leading-tight">
      Descubre las Rías Baixas
    </h1>

    <p class="text-blue-50 text-sm max-w-xs">
      Ajedrez, costa y gastronomía en el corazón de Galicia.
    </p>
  </div>
</div>
