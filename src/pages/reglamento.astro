---
import Layout from "@components/layouts/Layout.astro";

import ByesSection from "@components/pages/reglamento/ByesSection.astro";
import CompetitionSystemSection from "@components/pages/reglamento/CompetitionSystemSection.astro";
import DataProtectionSection from "@components/pages/reglamento/DataProtectionSection.astro";
import FinalProvisionsSection from "@components/pages/reglamento/FinalProvisionsSection.astro";
import GeneralInformationSection from "@components/pages/reglamento/GeneralInformationSection.astro";
import GroupsAndCategoriesSection from "@components/pages/reglamento/GroupsAndCategoriesSection.astro";
import PlayingRegulationsSection from "@components/pages/reglamento/PlayingRegulationsSection.astro";
import PontevedraSpecialRuleSection from "@components/pages/reglamento/PontevedraSpecialRuleSection.astro";
import RegistrationSection from "@components/pages/reglamento/RegistrationSection.astro";
import TableOfContentsSection from "@components/pages/reglamento/TableOfContentsSection.astro";
import TieBreaksSection from "@components/pages/reglamento/TieBreaksSection.astro";
import TimeControlSection from "@components/pages/reglamento/TimeControlSection.astro";
import TitleSection from "@components/pages/reglamento/TitleSection.astro";

const sections = [
  { id: "informacion-general", title: "Información general" },
  { id: "sistema-de-competicion", title: "Sistema de competición" },
  { id: "grupos-y-categorias", title: "Grupos y categorías" },
  { id: "ritmo-de-juego", title: "Ritmo de juego" },
  { id: "byes", title: "Byes" },
  { id: "desempates", title: "Desempates" },
  { id: "regla-especial-pontevedra", title: "Regla especial Pontevedra" },
  { id: "normativa-de-juego", title: "Normativa de juego" },
  { id: "inscripciones", title: "Inscripciones" },
  {
    id: "proteccion-de-datos-y-derechos-de-imagen",
    title: "Protección de datos y derechos de imagen",
  },
  { id: "disposiciones-finales", title: "Disposiciones finales" },
];
---

<Layout>
  <TitleSection />
  <TableOfContentsSection sections={sections}>
    <GeneralInformationSection />
    <CompetitionSystemSection />
    <GroupsAndCategoriesSection />
    <TimeControlSection />
    <ByesSection />
    <TieBreaksSection />
    <PontevedraSpecialRuleSection />
    <PlayingRegulationsSection />
    <RegistrationSection />
    <DataProtectionSection />
    <FinalProvisionsSection />
  </TableOfContentsSection>
</Layout>
