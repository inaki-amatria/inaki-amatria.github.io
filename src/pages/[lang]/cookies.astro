---
import Layout from "@components/layouts/Layout.astro";

import CookiePolicySection from "@components/pages/cookies/CookiePolicySection.astro";

import { type Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";
import { staticLangPaths } from "@i18n/utils.ts";

export const getStaticPaths = staticLangPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<Layout lang={lang} route={"cookies"} title={t("cookies.title")}>
  <CookiePolicySection lang={lang} />
</Layout>
