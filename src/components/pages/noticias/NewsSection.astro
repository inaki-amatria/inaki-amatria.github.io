---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface NoticiaFrontmatter {
  title: string;
  date: Date;
  excerpt: string;
  cover?: ImageMetadata;
  coverAlt?: string;
}

interface NoticiaModule {
  frontmatter: NoticiaFrontmatter;
}

interface Noticia extends NoticiaFrontmatter {
  slug: string;
}

const mods = import.meta.glob<NoticiaModule>("../../../pages/noticias/*.astro");

const noticias: Noticia[] = (
  await Promise.all(
    Object.entries(mods).map(async ([path, resolver]) => {
      const mod = await resolver();
      return {
        slug: path.split("/").pop()!.replace(".astro", ""),
        title: mod.frontmatter.title,
        date: mod.frontmatter.date,
        excerpt: mod.frontmatter.excerpt,
        cover: mod.frontmatter.cover,
        coverAlt: mod.frontmatter.coverAlt,
      };
    }),
  )
).sort((a, b) => b.date.valueOf() - a.date.valueOf());

const [featured, ...rest] = noticias;

const formatter = new Intl.DateTimeFormat("es-ES", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

{
  noticias.length === 0 && (
    <section class="content-section">
      <p>No hay noticias publicadas todavía.</p>
    </section>
  )
}

{
  featured && (
    <section class="content-section">
      <a href={`/noticias/${featured.slug}`}>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 card overflow-hidden">
          {/* Imagen */}
          {featured.cover ? (
            <div class="relative overflow-hidden aspect-video lg:aspect-auto lg:min-h-72">
              <Image
                src={featured.cover}
                alt={featured.coverAlt ?? featured.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-blue-900/40 to-transparent" />
            </div>
          ) : (
            <div class="bg-gradient-to-br from-blue-900 to-blue-950 lg:min-h-72 flex items-center justify-center">
              <span class="text-white/20 text-8xl font-serif italic select-none">
                N
              </span>
            </div>
          )}
          {/* Texto */}
          <div class="flex flex-col justify-center gap-4 p-6">
            <span class="pill-blue">Última noticia</span>

            <h3 class="text-2xl md:text-3xl font-bold text-blue-900 leading-tight">
              {featured.title}
            </h3>

            <p class="text-gray-600">{featured.excerpt}</p>

            <div class="flex items-center justify-between mt-2">
              <span class="text-gray-400 text-xs">
                {formatter.format(featured.date)}
              </span>
              <span class="link text-sm">Leer más →</span>
            </div>
          </div>
        </div>
      </a>
    </section>
  )
}

{
  rest.length > 0 && (
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
      {rest.map((noticia) => (
        <a href={`/noticias/${noticia.slug}`} class="card overflow-hidden">
          {/* Imagen */}
          {noticia.cover ? (
            <div class="relative overflow-hidden aspect-video">
              <Image
                src={noticia.cover}
                alt={noticia.coverAlt ?? noticia.title}
                class="absolute inset-0 w-full h-full object-cover"
              />
            </div>
          ) : (
            <div class="bg-gradient-to-br from-blue-900 to-blue-950 aspect-video flex items-center justify-center">
              <span class="text-white/20 text-6xl font-serif italic select-none">
                N
              </span>
            </div>
          )}
          {/* Texto */}
          <div class="flex flex-col gap-4 p-6">
            <h3 class="text-lg font-bold text-blue-900 leading-tight line-clamp-2">
              {noticia.title}
            </h3>
            <p class="text-gray-600 text-sm line-clamp-2">{noticia.excerpt}</p>
            <span class="text-gray-400 text-xs mt-auto">
              {formatter.format(noticia.date)}
            </span>
          </div>
        </a>
      ))}
    </section>
  )
}
