---
import Layout from "@components/layouts/Layout.astro";

import ContactFormSection from "@components/pages/contacto/ContactFormSection.astro";
import FindUsSection from "@components/pages/contacto/FindUsSection.astro";
import TitleSection from "@components/pages/contacto/TitleSection.astro";

import { type Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";
import { staticLangPaths } from "@i18n/utils.ts";

export const getStaticPaths = staticLangPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<Layout lang={lang} route={"contacto"} title={t("contacto.title")}>
  <TitleSection lang={lang} />
  <ContactFormSection lang={lang} />
  <FindUsSection lang={lang} />
</Layout>
