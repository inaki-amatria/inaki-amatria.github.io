---
import type { Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";
import { getPath } from "@i18n/utils.ts";

export interface Props {
  lang: Lang;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang);
---

<p>{t(`${slug}.p1`)}</p>
<h2 class="section-subheading">{t(`${slug}.h1`)}</h2>
<p>{t(`${slug}.p2`)}</p>
<ul class="list-disc ml-12 space-y-2">
  <li>{t(`${slug}.li1`)}</li>
  <li>{t(`${slug}.li2`)}</li>
</ul>
<h2 class="section-subheading">{t(`${slug}.h2`)}</h2>
<p>
  {t(`${slug}.p3`)}
  <a href="mailto:escola@xadrezpontevedra.com" class="inline-link">
    escola@xadrezpontevedra.com
  </a>
  {t(`${slug}.p3b`)} 650 645 318.
</p>
<p>{t(`${slug}.p4`)}</p>
<h2 class="section-subheading">{t(`${slug}.h3`)}</h2>
<p>
  {t(`${slug}.p5`)}
  <a href={getPath(lang, "bases")} class="inline-link">
    {t(`${slug}.cta`)}
  </a>
  {t(`${slug}.p5b`)}
</p>
