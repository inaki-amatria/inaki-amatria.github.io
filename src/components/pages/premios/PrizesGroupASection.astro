<section class="flex flex-col gap-8 mb-12">
  <h2 class="section-heading">Grupo A</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div
      class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-blue-900 via-blue-900 to-blue-950 p-6 flex flex-col gap-2 justify-end shadow-lg min-h-48"
    >
      <div
        class="absolute top-4 right-4 text-white/10 font-serif italic font-bold text-8xl leading-none select-none"
      >
        1
      </div>
      <span
        class="text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest bg-white/10 text-blue-200 w-fit"
        >1.er clasificado</span
      >
      <span class="text-white text-5xl font-bold font-serif italic leading-none"
        >2.000&euro;</span
      >
      <span class="text-blue-50/60 text-sm">+ Trofeo</span>
    </div>

    <div
      class="relative overflow-hidden card p-6 flex flex-col gap-2 justify-end min-h-48"
    >
      <div
        class="absolute top-4 right-4 text-blue-900/5 font-serif italic font-bold text-8xl leading-none select-none"
      >
        2
      </div>
      <span class="pill-blue w-fit">2.do clasificado</span>
      <span
        class="text-blue-900 text-5xl font-bold font-serif italic leading-none"
        >1.200&euro;</span
      >
      <span class="text-gray-600 text-sm">+ Trofeo</span>
    </div>

    <div
      class="relative overflow-hidden card p-6 flex flex-col gap-2 justify-end min-h-48"
    >
      <div
        class="absolute top-4 right-4 text-blue-900/5 font-serif italic font-bold text-8xl leading-none select-none"
      >
        3
      </div>
      <span class="pill-blue w-fit">3.er clasificado</span>
      <span
        class="text-blue-900 text-5xl font-bold font-serif italic leading-none"
        >800&euro;</span
      >
      <span class="text-gray-600 text-sm">+ Trofeo</span>
    </div>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
    {
      [
        { pos: "4.º", prize: "700€" },
        { pos: "5.º", prize: "600€" },
        { pos: "6.º", prize: "500€" },
        { pos: "7.º", prize: "400€" },
        { pos: "8.º", prize: "300€" },
        { pos: "9.º", prize: "250€" },
        { pos: "10.º", prize: "250€" },
        { pos: "11.º", prize: "200€" },
        { pos: "12.º", prize: "200€" },
        { pos: "13.º", prize: "150€" },
        { pos: "14.º", prize: "150€" },
        { pos: "15.º", prize: "150€" },
      ].map(({ pos, prize }) => (
        <div class="bg-white rounded-2xl shadow-md px-4 py-3 flex items-center justify-between gap-2">
          <span class="text-gray-600 text-sm">{pos}</span>
          <span class="text-blue-900 font-bold text-sm">{prize}</span>
        </div>
      ))
    }
  </div>

  <div class="flex items-center gap-4">
    <div class="h-px bg-gray-200 flex-1"></div>
    <span class="text-xs font-bold uppercase tracking-widest text-gray-400"
      >Premios especiales</span
    >
    <div class="h-px bg-gray-200 flex-1"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {
      [
        { label: "1.º Sub-2300", prize: "150€" },
        { label: "1.º Sub-2150", prize: "150€" },
        { label: "Mejor clasificada femenina", prize: "150€ + Trofeo" },
        { label: "Mejor veterano", prize: "Trofeo + Libro" },
      ].map(({ label, prize }) => (
        <div class="bg-white rounded-2xl shadow-md px-4 py-3 flex items-center justify-between gap-2">
          <span class="text-gray-600 text-sm">{label}</span>
          <span class="text-blue-900 font-bold text-sm shrink-0 ml-4">
            {prize}
          </span>
        </div>
      ))
    }
  </div>
</section>
