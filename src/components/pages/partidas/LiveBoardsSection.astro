---
import LiveBoardsIsland from "./LiveBoardsIsland.tsx";
import { Globe, Radio, Database } from "lucide-astro";

const platforms = [
  {
    name: "Chess.com",
    url: "https://www.chess.com/events/2025-pontevedra-open/games",
    description: "Seguimiento en directo con análisis de motor.",
    Icon: Globe,
  },
  {
    name: "Lichess",
    url: "https://lichess.org/broadcast/13th-pontevedra-open-2025/round-1/xrbdCF4G",
    description: "Retransmisión oficial del torneo.",
    Icon: Radio,
  },
  {
    name: "ChessBase",
    url: "https://live.chessbase.com/en/watch/13th-Pontevedra-Open-Masters-2025/",
    description: "Partidas en directo con tableros interactivos.",
    Icon: Database,
  },
];
---

<section class="flex flex-col gap-8 mb-12">
  <div class="flex flex-col gap-4">
    <h2 class="section-heading">Sigue el torneo en directo</h2>
    <p class="text-gray-600">
      Sigue las partidas en tiempo real desde las principales plataformas de
      ajedrez online.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    {
      platforms.map(({ name, url, description, Icon }) => (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="card p-6 flex flex-col gap-4"
        >
          <div class="w-10 h-10 rounded-2xl bg-blue-50 flex items-center justify-center">
            <Icon class="w-5 h-5 text-blue-900" />
          </div>

          <div class="flex flex-col gap-2">
            <span class="label">{name}</span>
            <p class="text-gray-600 text-sm">{description}</p>
          </div>

          <span class="link text-sm mt-auto">Ver partidas →</span>
        </a>
      ))
    }
  </div>

  <LiveBoardsIsland client:load />
</section>
