---
import type { Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="normativa-de-juego" class="content-section">
  <h2 class="section-heading">
    {t("PlayingRegulationsSection.title")}
  </h2>

  <h3 class="section-subheading">
    {t("PlayingRegulationsSection.generalTitle")}
  </h3>

  <p>
    {t("PlayingRegulationsSection.generalP1")}
  </p>

  <p>
    {t("PlayingRegulationsSection.generalP2")}
  </p>

  <p>
    {t("PlayingRegulationsSection.generalP3")}
  </p>

  <p>
    {t("PlayingRegulationsSection.generalP4")}
  </p>

  <h3 class="section-subheading">
    {t("PlayingRegulationsSection.appealTitle")}
  </h3>

  <p>
    {t("PlayingRegulationsSection.appealP1")}
  </p>

  <p>
    {t("PlayingRegulationsSection.appealP2")}
  </p>

  <p>
    {t("PlayingRegulationsSection.appealP3")}
  </p>

  <p>
    {t("PlayingRegulationsSection.appealP4")}
  </p>

  <h3 class="section-subheading">
    {t("PlayingRegulationsSection.antiCheatingTitle")}
  </h3>

  <p>
    {t("PlayingRegulationsSection.antiCheatingP")}
  </p>

  <ul class="list-disc ml-12 space-y-2">
    <li>
      {t("PlayingRegulationsSection.antiCheatingLi1")}
    </li>
    <li>
      {t("PlayingRegulationsSection.antiCheatingLi2")}
    </li>
    <li>
      {t("PlayingRegulationsSection.antiCheatingLi3")}
    </li>
    <li>
      {t("PlayingRegulationsSection.antiCheatingLi4")}
    </li>
    <li>
      {t("PlayingRegulationsSection.antiCheatingLi5")}
    </li>
  </ul>

  <h3 class="section-subheading">
    {t("PlayingRegulationsSection.conductTitle")}
  </h3>

  <p>
    {t("PlayingRegulationsSection.conductP1")}
  </p>

  <p>
    {t("PlayingRegulationsSection.conductP2")}
  </p>

  <p>
    {t("PlayingRegulationsSection.conductP3")}
  </p>
</section>
