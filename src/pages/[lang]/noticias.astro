---
import Layout from "@components/layouts/Layout.astro";

import NewsSection from "@components/pages/noticias/NewsSection.astro";
import TitleSection from "@components/pages/noticias/TitleSection.astro";

import { type Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";
import { staticLangPaths } from "@i18n/utils.ts";

export const getStaticPaths = staticLangPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<Layout lang={lang} route={"noticias"} title={t("noticias.title")}>
  <TitleSection lang={lang} />
  <NewsSection lang={lang} />
</Layout>
