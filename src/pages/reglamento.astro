import FinalProvisionsSection from "@components/pages/reglamento/FinalProvisionsSection.astro";
import GeneralInformationSection from "@components/pages/reglamento/GeneralInformationSection.astro";
import GroupsAndCategoriesSection from "@components/pages/reglamento/GroupsAndCategoriesSection.astro";
import PlayingRegulationsSection from "@components/pages/reglamento/PlayingRegulationsSection.astro";
