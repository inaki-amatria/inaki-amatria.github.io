---
import { Image } from "astro:assets";

import type { ImageMetadata } from "astro";

import type { Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";
import { getPath } from "@i18n/utils.ts";

import Layout from "./Layout.astro";

export interface Props {
  lang: Lang;
  slug: string;
  date: Date;
  cover?: ImageMetadata;
}

const { lang, slug, date, cover } = Astro.props;
const t = useTranslations(lang);

const formatter = new Intl.DateTimeFormat(lang, {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout lang={lang} route={`noticias/${slug}`} title={t(`${slug}.title`)}>
  <article class="mb-12">
    <header class="flex flex-col gap-4 mb-12">
      <a href={getPath(lang, "noticias")} class="link text-sm mb-4 w-fit">
        ← {t(`ArticleLayout.backToNews`)}
      </a>
      <h1 class="section-heading">{t(`${slug}.title`)}</h1>
      <p class="text-gray-600 text-lg">{t(`${slug}.excerpt`)}</p>
      <span class="text-gray-400 text-sm">{formatter.format(date)}</span>
    </header>

    {
      cover && (
        <div class="relative overflow-hidden rounded-3xl shadow-lg aspect-video md:aspect-[21/7] mb-12">
          <Image
            src={cover}
            alt={t(`${slug}.title`)}
            class="absolute inset-0 w-full h-full object-cover"
            quality="high"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-blue-900/40 to-transparent" />
        </div>
      )
    }

    <section class="content-section">
      <slot />
    </section>
  </article>
</Layout>
