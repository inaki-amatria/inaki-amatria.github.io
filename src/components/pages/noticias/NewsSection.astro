---
import { Image } from "astro:assets";

import type { Lang } from "@i18n/config.ts";
import { news } from "@i18n/news.ts";
import { useTranslations } from "@i18n/ui.ts";
import { getPath } from "@i18n/utils.ts";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const sorted = [...news].sort((a, b) => b.date.valueOf() - a.date.valueOf());
const [featured, ...rest] = sorted.map((n) => ({
  ...n,
  title: t(`${n.slug}.title`),
  excerpt: t(`${n.slug}.excerpt`),
}));

const formatter = new Intl.DateTimeFormat(lang, {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

{
  sorted.length === 0 && (
    <section class="content-section">
      <p>{t("NewsSection.empty")}</p>
    </section>
  )
}

{
  featured && (
    <section class="content-section">
      <a href={getPath(lang, `noticias/${featured.slug}`)}>
        <div class="grid grid-cols-1 lg:grid-cols-2 card overflow-hidden">
          {/* Imagen */}
          {featured.cover ? (
            <div class="relative overflow-hidden aspect-video lg:aspect-auto lg:min-h-72">
              <Image
                src={featured.cover}
                alt={featured.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500"
                quality="high"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-blue-900/40 to-transparent" />
            </div>
          ) : (
            <div class="bg-gradient-to-br from-blue-900 to-blue-950 lg:min-h-72 flex items-center justify-center">
              <span class="text-white/20 text-8xl font-serif italic select-none">
                N
              </span>
            </div>
          )}
          {/* Texto */}
          <div class="flex flex-col justify-center gap-4 p-6">
            <span class="pill-blue">{t("NewsSection.latest")}</span>
            <h3 class="text-2xl md:text-3xl font-bold text-blue-900 leading-tight">
              {featured.title}
            </h3>

            <p class="text-gray-600">{featured.excerpt}</p>

            <div class="flex items-center justify-between mt-2">
              <span class="text-gray-400 text-xs">
                {formatter.format(featured.date)}
              </span>
              <span class="link text-sm">{t("NewsSection.readMore")} →</span>
            </div>
          </div>
        </div>
      </a>
    </section>
  )
}

{
  rest.length > 0 && (
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
      {rest.map((noticia) => (
        <a
          href={getPath(lang, `noticias/${noticia.slug}`)}
          class="card overflow-hidden"
        >
          {/* Imagen */}
          {noticia.cover ? (
            <div class="relative overflow-hidden aspect-video">
              <Image
                src={noticia.cover}
                alt={noticia.title}
                class="absolute inset-0 w-full h-full object-cover"
                quality="high"
                loading="eager"
              />
            </div>
          ) : (
            <div class="bg-gradient-to-br from-blue-900 to-blue-950 aspect-video flex items-center justify-center">
              <span class="text-white/20 text-6xl font-serif italic select-none">
                N
              </span>
            </div>
          )}
          {/* Texto */}
          <div class="flex flex-col gap-4 p-6">
            <h3 class="text-lg font-bold text-blue-900 leading-tight line-clamp-2">
              {noticia.title}
            </h3>
            <p class="text-gray-600 text-sm line-clamp-2">{noticia.excerpt}</p>
            <span class="text-gray-400 text-xs mt-auto">
              {formatter.format(noticia.date)}
            </span>
          </div>
        </a>
      ))}
    </section>
  )
}
