---
export interface Props {
  sections: { id: string; title: string }[];
}

const { sections } = Astro.props;
---

<div class="flex flex-col lg:flex-row gap-12">
  <details class="lg:hidden sticky top-6 bg-white rounded-xl shadow-md">
    <summary
      class="cursor-pointer list-none z-20 px-4 py-3 flex justify-between items-center text-blue-900 font-bold"
    >
      Reglamento
      <span class="toc-arrow text-sm">▼</span>
    </summary>

    <nav>
      {
        sections.map((section) => (
          <a
            href={`#${section.id}`}
            class="block px-4 py-3 text-sm hover:bg-blue-50 link"
          >
            {section.title}
          </a>
        ))
      }
    </nav>
  </details>

  <div class="flex-1">
    <slot />
  </div>

  <aside class="hidden lg:block sticky top-12 mb-12 max-w-72 self-start">
    <nav class="flex flex-col">
      {
        sections.map((section) => (
          <a
            href={`#${section.id}`}
            class="border-l border-gray-200 pl-4 pt-2 pb-2 link hover:border-blue-900 text-sm"
          >
            {section.title}
          </a>
        ))
      }
    </nav>
  </aside>
</div>

<style>
  details[open] .toc-arrow {
    transform: rotate(180deg);
  }

  .toc-arrow {
    transition: transform 0.3s ease;
  }
</style>

<script defer>
  const offset = 90;

  const handleClick = (link) => {
    const targetId = link.getAttribute("href")?.substring(1);
    if (!targetId) {
      return;
    }

    const target = document.getElementById(targetId);
    if (!target) {
      return;
    }

    const details = link.closest("details.lg\\:hidden");
    details?.removeAttribute("open");

    const top =
      target.getBoundingClientRect().top + window.pageYOffset - offset;
    window.scrollTo({ top, behavior: "smooth" });
  };

  document.addEventListener("click", (e) => {
    const link = e.target.closest("a.link");
    if (!link) {
      return;
    }
    e.preventDefault();
    handleClick(link);
  });
</script>
