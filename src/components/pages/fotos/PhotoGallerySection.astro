---
import { Image } from "astro:assets";

import XIIIEditionAlbumCover from "@assets/images/XIIIEditionAlbumCover.webp";
import XIIEditionAlbumCover from "@assets/images/XIIEditionAlbumCover.webp";
import XIEditionAlbumCover from "@assets/images/XIEditionAlbumCover.webp";

import type { Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const albums = [
  {
    year: 2025,
    edition: "XIII",
    url: "https://photos.app.goo.gl/7erxMmp49NkAwm8k7",
    cover: XIIIEditionAlbumCover,
    photoCount: 795,
  },
  {
    year: 2024,
    edition: "XII",
    url: "https://photos.app.goo.gl/zTQrmgKj7ZBq2pnA9",
    cover: XIIEditionAlbumCover,
    photoCount: 403,
  },
  {
    year: 2023,
    edition: "XI",
    url: "https://photos.app.goo.gl/kFtfk1wscbso7pE78",
    cover: XIEditionAlbumCover,
    photoCount: 975,
  },
];
---

<section class="flex flex-col gap-8 mb-12">
  {
    albums.map(({ year, edition, url, cover, photoCount }) => (
      <div class="flex flex-col md:flex-row gap-8 items-center">
        {/* Imagen de portada */}
        <div class="w-full md:w-3/5 flex-shrink-0">
          <a href={url} target="_blank" rel="noopener noreferrer">
            <div class="card overflow-hidden aspect-video flex items-center justify-center group">
              <Image
                src={cover}
                alt={`${edition} ${t("PhotoGallerySection.tournamentName")} ${t("PhotoGallerySection.city")}`}
                class="w-full h-full object-cover"
                quality="high"
                loading="eager"
              />
            </div>
          </a>
        </div>

        {/* Texto */}
        <div class="flex flex-col gap-4">
          <span class="pill-blue">{year}</span>

          <h3 class="text-2xl md:text-3xl font-bold text-blue-900 leading-tight">
            <span class="font-serif italic">{edition}</span>{" "}
            {t("PhotoGallerySection.tournamentName")}
            <br />
            {t("PhotoGallerySection.city")}
          </h3>

          <p class="text-gray-600 text-sm">
            {photoCount} {t("PhotoGallerySection.photos")}
          </p>

          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="button-primary w-fit"
          >
            {t("PhotoGallerySection.viewAlbum")}
          </a>
        </div>
      </div>
    ))
  }
</section>
