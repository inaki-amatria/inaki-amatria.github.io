---
import Layout from "@components/layouts/Layout.astro";

import ChessServersSection from "@components/pages/partidas/ChessServersSection.astro";
import LiveBoardsSection from "@components/pages/partidas/LiveBoardsSection.astro";
import TitleSection from "@components/pages/partidas/TitleSection.astro";

import { type Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";
import { staticLangPaths } from "@i18n/utils.ts";

export const getStaticPaths = staticLangPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<Layout lang={lang} route={"partidas"} title={t("partidas.title")}>
  <TitleSection lang={lang} />
  <ChessServersSection lang={lang} />
  <LiveBoardsSection lang={lang} />
</Layout>
