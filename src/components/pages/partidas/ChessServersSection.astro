---
import { Globe, Radio, Database } from "@lucide/astro";

import type { Lang } from "@i18n/config.ts";
import { useTranslations } from "@i18n/ui.ts";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const platforms = [
  {
    name: "Chess.com",
    url: "https://www.chess.com/events/2025-pontevedra-open/games",
    description: t("ChessServersSection.chesscomDesc"),
    Icon: Globe,
  },
  {
    name: "Lichess",
    url: "https://lichess.org/broadcast/13th-pontevedra-open-2025/round-1/xrbdCF4G",
    description: t("ChessServersSection.lichessDesc"),
    Icon: Radio,
  },
  {
    name: "ChessBase",
    url: "https://live.chessbase.com/en/watch/13th-Pontevedra-Open-Masters-2025/",
    description: t("ChessServersSection.chessbaseDesc"),
    Icon: Database,
  },
];
---

<section class="mb-12">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    {
      platforms.map(({ name, url, description, Icon }) => (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="card p-6 flex flex-col gap-4"
        >
          <div class="w-10 h-10 rounded-2xl bg-blue-50 flex items-center justify-center">
            <Icon class="w-5 h-5 text-blue-900" />
          </div>

          <div class="flex flex-col gap-2">
            <span class="label">{name}</span>
            <p class="text-gray-600 text-sm">{description}</p>
          </div>

          <span class="link text-sm mt-auto">
            {t("ChessServersSection.viewGames")} →
          </span>
        </a>
      ))
    }
  </div>
</section>
