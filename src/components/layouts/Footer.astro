---
import Facebook from "@assets/icons/Facebook.svg";
import Instagram from "@assets/icons/Instagram.svg";
import Twitter from "@assets/icons/Twitter.svg";
import YouTube from "@assets/icons/YouTube.svg";

import ManageCookiesIsland from "@components/global/ManageCookiesIsland.tsx";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/bases", label: "Bases técnicas" },
  { href: "/premios", label: "Premios" },
  { href: "/jugadores", label: "Jugadores" },
  { href: "/partidas", label: "Partidas" },
  { href: "/alojamiento", label: "Alojamiento" },
  { href: "/fotos", label: "Fotos" },
  { href: "/noticias", label: "Noticias" },
  { href: "/contacto", label: "Contacto" },
];

const legalLinks = [
  { href: "/privacidad", label: "Privacidad" },
  { href: "/cookies", label: "Cookies" },
];

const socialLinks = {
  facebook: {
    href: "https://facebook.com/escola.pontevedra",
    Icon: Facebook,
    label: "Facebook",
  },
  instagram: {
    href: "https://www.instagram.com/expontevedra",
    Icon: Instagram,
    label: "Instagram",
  },
  twitter: {
    href: "https://x.com/xadrezpontevedr",
    Icon: Twitter,
    label: "Twitter / X",
  },
  youtube: {
    href: "https://www.youtube.com/channel/UCddRc4mlget43r8rA8Ac13A",
    Icon: YouTube,
    label: "YouTube",
  },
};
---

<footer class="border-t border-gray-200">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-12 py-12">
    <div class="flex flex-col gap-4">
      <h4 class="label-sm">Navegación</h4>
      <nav class="flex flex-col gap-2">
        {
          links.map((link) => (
            <a href={link.href} class="link text-sm">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="flex flex-col gap-4">
      <h4 class="label-sm">Legal</h4>
      <nav class="flex flex-col gap-2">
        <ManageCookiesIsland class="link text-sm" client:load />
        {
          legalLinks.map((link) => (
            <a href={link.href} class="link text-sm">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="flex flex-col gap-4">
      <h4 class="label-sm">Síguenos</h4>
      <div class="flex flex-wrap gap-4">
        {
          Object.values(socialLinks).map(({ href, label, Icon }) => (
            <a
              href={href}
              aria-label={label}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-blue-50 p-3 rounded-2xl text-blue-900 hover:bg-blue-900 hover:text-white shadow-sm transition-all duration-300"
            >
              <Icon class="w-5 h-5" />
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <p
    class="border-t border-gray-200 text-xs text-gray-600 py-6 flex flex-col sm:flex-row sm:justify-between gap-2"
  >
    <span
      >&copy; {new Date().getFullYear()} Torneo Internacional Ciudad de Pontevedra.
      Todos los derechos reservados.</span
    >
    <span
      >Diseño y desarrollo: <a
        href="https://amatria.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="link">amatria.dev</a
      >.</span
    >
  </p>
</footer>
